  "shortcuts": [
    {
      "name": "Hirdetés feladása",
      "short_name": "Új hirdetés",
      "description": "Adj fel új hirdetést gyorsan",
      "url": "/?action=new-listing",
      "icons": [
        {
          "src": "/icons/shortcut-new.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Keresés",
      "short_name": "Keresés",
      "description": "Keress a hirdetések között",
      "url": "/?action=search",
      "icons": [
        {
          "src": "/icons/shortcut-search.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Üzenetek",
      "short_name": "Üzenetek",
      "description": "Olvasd el az üzeneteidet",
      "url": "/?action=messages",
      "icons": [
        {
          "src": "/icons/shortcut-messages.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Kedvencek",
      "short_name": "Kedvencek",
      "description": "Mentett hirdetéseid",
      "url": "/?action=favorites",
      "icons": [
        {
          "src": "/icons/shortcut-favorites.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://piacter.hu/manifest.json"
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+piacter",
      "url": "/?protocol=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/upload",
      "accept": {
        "image/*": [ ".jpg", ".jpeg", ".png", ".webp", ".gif" ]
      }
    }
  ],
  "display_override": [ "window-controls-overlay", "standalone", "browser" ],
  "edge_side_panel": {
    "preferred_width": 400
  }
}
